# ============================================
# OH YEAH! — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# NON committare mai .env su Git!
# ============================================

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...tua_anon_key_qui

# --- OpenAI ---
OPENAI_API_KEY=sk-...tua_key_qui

# --- Brevo (Email) ---
BREVO_API_KEY=xkeysib-...tua_key_qui
BREVO_SENDER_EMAIL=noreply@ohyeahhub.it
BREVO_SENDER_NAME=OH YEAH! Hub
BREVO_REPLY_TO_EMAIL=info@ohyeahhub.it
BREVO_REPLY_TO_NAME=OH YEAH! Hub
BREVO_BCC_EMAIL=

# --- Admin (opzionale) ---
ADMIN_EMAILS=admin@example.com

# --- Debug (opzionale) ---
# DEBUG_MODE=1

# --- FastAPI Worker (Fase 3 — AI/parsing separato) ---
# Usato quando il container worker è attivo: docker-compose --profile worker up
# Lascia vuoto (o ometti) per usare le funzioni locali come fallback.
WORKER_BASE_URL=http://worker:8000
