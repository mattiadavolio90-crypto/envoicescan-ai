{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "PowerShell(*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(del:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TodoWrite(*)",
      "Agent(*)",
      "mcp__claude_ai_Supabase__get_advisors"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/claude_hook_promemoria.py"
          }
        ]
      }
    ]
  }
}
